# Adaptive Grid Bot — Environment Variables
# Copy this to .env and fill in your values
# Or set these in Railway dashboard under Variables

# Binance API credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Trading config
SYMBOL=BTCUSDT
LEVERAGE=5
RISK_PCT=0.02
INITIAL_CAPITAL=100

# Set to 'false' for real trading (USE WITH CAUTION)
TESTNET=true
